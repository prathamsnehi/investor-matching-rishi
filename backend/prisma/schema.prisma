generator client {
  provider        = "prisma-client-py"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector] // Enables pgvector
}

//enums

enum AccountRole {
  FOUNDER
  INVESTOR
}

enum TRL {
  IDEA
  PROTOTYPE
  PILOT
  LIVE_PRODUCT
  SCALING
}

enum FundingStage {
  PRE_SEED
  SEED
  PRE_SERIES_A
}

enum InteractionAction {
  PASS           // Translates to y = 0 for ML training
  RIGHT_SWIPE    // Translates to y = 1 for ML training
  INTRO_REQUEST  // Translates to y = 1 for ML training
}

//core models

model Account {
  id                   String   @id @default(uuid())
  role                 AccountRole
  full_name            String
  email_address        String   @unique
  mobile_number        String   @unique
  linkedin_profile_url String
  photo_url            String?  
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  founderProfile       FounderProfile?
  investorProfile      InvestorProfile?
}

model FounderProfile {
  id                   String   @id @default(uuid())
  accountId            String   @unique
  account              Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // 02: Startup Identity
  startup_name         String
  one_line_desc        String   @db.VarChar(140)
  full_desc            String
  
  // 03 & 04: Hard Filter Fields
  stage                FundingStage
  trl                  TRL
  target_raise_inr     Float
  min_cheque_inr       Float

  // ML / Semantic Field
  // Stores the embedding of the combined startup text (desc, bios, etc.)
  // Assuming a 384-dimensional model like all-MiniLM-L6-v2
  embedding            Unsupported("vector(384)")?

  // Relationships
  receivedInteractions Interaction[] @relation("ReceivedInteractions")
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // Note: Add remaining basic text fields (website, team size, etc.) here.
}

model InvestorProfile {
  id                   String   @id @default(uuid())
  accountId            String   @unique
  account              Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // 02: Investor Background
  investor_type        String
  brief_bio            String

  // 03 & 04: Hard Filter Preferences
  preferred_stages     FundingStage[] // Array of accepted stages
  min_trl_accepted     TRL
  min_cheque_inr       Float
  max_cheque_inr       Float

  // ML / Semantic Field
  embedding            Unsupported("vector(384)")?

  // Relationships
  initiatedInteractions Interaction[] @relation("InitiatedInteractions")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // Note: Add remaining arrays (sectors, business models) here.
}

// --- MLOps / TELEMETRY MODEL ---

model Interaction {
  id               String            @id @default(uuid())
  
  investorId       String
  investor         InvestorProfile   @relation("InitiatedInteractions", fields: [investorId], references: [id])
  
  founderId        String
  founder          FounderProfile    @relation("ReceivedInteractions", fields: [founderId], references: [id])
  
  action           InteractionAction
  
  // Snapshot of the ML confidence score at the exact time of the swipe.
  // Critical for detecting "Model Drift" over time.
  ml_score_at_time Float?            

  createdAt        DateTime          @default(now())

  @@unique([investorId, founderId]) // Prevents duplicate swipe records
}